#!/usr/bin/env ruby
# xc — xcode project management for people who hate Xcode
require 'xcodeproj'
require 'fileutils'
require 'optparse'
require 'pathname'
require 'open3'
require 'json'
require 'tty-spinner'
require 'colored2'

class XC
  def initialize
    @version = '0.2.2'
    @operation_root = Dir.pwd
    @project_root, @project_path = find_project_root
    @project = @project_path ? Xcodeproj::Project.open(@project_path) : nil
    @project_name = @project_path ? File.basename(@project_path, '.xcodeproj') : nil

    @options = { targets: [], all_targets: false, verbose: false, force: false,
                 release: false, derived_data: nil, console: false }

    Dir.chdir(@project_root || @operation_root)
  end

  def run
    command = ARGV.shift
    parse_options

    if %w(add remove rename list targets build run open).include? command
      require_project!
    end

    case command
    when 'add' then add_path(ARGV.shift || ".")
    when 'remove' then remove_path(ARGV.shift || ".")
    when 'rename' then rename_path(ARGV.shift, ARGV.shift)
    when 'list' then list_files
    when 'targets' then list_targets
    when 'build' then build
    when 'run' then run_app
    when 'open'
      puts "Opening #{@project_path} in Xcode..."
      system('open', @project_path)
    when '--help', '-h', nil then help
    when '--version', '-v'
      puts "xc #{@version}"
      exit
    else
      puts "Unknown command: #{command}"
      help
      exit 1
    end

    @project.save if %w[add remove rename].include?(command)
  end

  # --- Options ---
  def parse_options
    OptionParser.new do |opts|
      opts.on("--target NAME") { |t| @options[:targets] << t }
      opts.on("--all-targets") { @options[:all_targets] = true }
      opts.on("--verbose") { @options[:verbose] = true }
      opts.on("--release") { @options[:release] = true }
      opts.on("--derived-data-path PATH") { |p| @options[:derived_data] = p }
      opts.on("--console") { @options[:console] = true }
    end.parse!(ARGV)
  end

  # --- Listing ---
  def list_targets
    puts "Available targets:"
    @project.targets.each { |t| puts "- #{t.name}" }
  end

  def list_files
    puts "Listing files by target:"
    @project.targets.each do |t|
      puts "#{t.name}:"
      t.source_build_phase.files.each { |bf| puts "  #{bf.file_ref&.path || '<unknown>'}" }
    end

    puts "\nImplicit Swift files (not in project, but compiler includes them):"
    swift_files = Dir.glob("**/*.swift").reject { |f| f.start_with?(".") }
    project_files = @project.files.map(&:path)
    (swift_files - project_files).each { |f| puts "  #{f}" }
  end

  # --- Add ---
  def add_path(path)
    abs_path = File.expand_path(path, @operation_root)
    unless File.exist?(abs_path)
      puts "File/folder does not exist: #{path}"
      return
    end
    File.directory?(abs_path) ? add_folder(abs_path, resolve_targets) : add_file(abs_path, resolve_targets)
  end

  # Recursively add folders/files, passing down Xcode group path
  def add_folder(folder_path, targets, parent_group = nil)
    return if File.basename(folder_path).start_with?('.')
    parent_group ||= @project.main_group

    # If it's a bundle (blue folder), add directly
    if bundle_directory?(folder_path)
      rel_path = relative_path(folder_path)
      unless @project.files.find { |f| f.path == rel_path }
        parent_group.new_reference(rel_path)
        puts "Added bundle #{rel_path}" if @options[:verbose]
      end
      return
    end

    # Use only the folder name for the group, do NOT prepend parent paths
    group_name = File.basename(folder_path)
    group = parent_group.groups.find { |g| g.name == group_name } || parent_group.new_group(group_name)

    Dir.children(folder_path).each do |entry|
      next if entry.start_with?(".")
      full = File.join(folder_path, entry)
      if File.directory?(full)
        add_folder(full, targets, group)  # pass down current Xcode group
      else
        add_file(full, targets, group)
      end
    end
  end

  # Add single file to project and target(s)
  def add_file(file_path, targets, group = nil)
    abs_file = File.expand_path(file_path)
    group ||= group_for_folder(File.dirname(abs_file))
    rel_path = relative_path(abs_file)
    return if @project.files.find { |f| f.path == rel_path }

    file_ref = group.new_file(rel_path)

    targets.each do |t_name|
      target = @project.targets.find { |t| t.name == t_name }
      next unless target
      unless target.source_build_phase.files.any? { |bf| bf.file_ref == file_ref }
        target.source_build_phase.add_file_reference(file_ref)
        puts "Added #{file_ref.path} → #{t_name}" if @options[:verbose]
      end
    end
  end

  # Return or create a group for a folder
  def group_for_folder(folder_path, parent_group = @project.main_group)
    rel_path = relative_path(folder_path)
    return parent_group if rel_path.empty?

    parts = rel_path.split(File::SEPARATOR)
    current = parent_group

    parts.each do |part|
      existing = current.groups.find { |g| g.name == part || (g.path && File.basename(g.path) == part) }
      current = existing || current.new_group(part, File.join(current.path.to_s, part))
    end

    current
  end

  # --- Remove ---
  def remove_path(path, target = nil)
    abs_path = File.expand_path(path, @operation_root)
    bundle = enclosing_bundle(abs_path)

    if bundle && same_path?(bundle, abs_path)
      remove_file(bundle, target)
      return
    elsif bundle
      puts "Skipping removal inside bundle #{bundle}" if @options[:verbose]
      return
    end

    if File.directory?(abs_path)
      Dir.glob("#{abs_path}/**/*").each do |file|
        next if File.directory?(file) || File.basename(file).start_with?('.')
        remove_file(file, target)
      end
      remove_group_for_path(abs_path)
    else
      remove_file(abs_path, target)
    end
  end

  def remove_file(file, target = nil)
    rel_path = relative_path(file)
    file_ref = @project.files.find { |f| f.path == rel_path }
    return unless file_ref

    @project.targets.each do |t|
      t.build_phases.each { |phase| phase.remove_file_reference(file_ref) if phase.respond_to?(:remove_file_reference) }
    end

    puts "Removed #{rel_path}" if @options[:verbose]
    file_ref.remove_from_project
  end

  def remove_group_for_path(path)
    rel = relative_path(path)
    group = find_group_by_path(rel)
    return unless group
    parent = group.parent rescue nil
    puts "Removing group #{group.name}" if @options[:verbose]
    group.remove_from_project
    prune_empty_groups(parent)
  end

  def prune_empty_groups(start_group)
    group = start_group
    while group && group != @project.main_group
      break unless group.children.empty?
      parent = group.parent rescue nil
      puts "Pruned empty group #{group.name}" if @options[:verbose]
      group.remove_from_project
      group = parent
    end
  end

  # --- Rename ---
  def rename_path(old_path, new_path)
    abs_old = File.expand_path(old_path, @operation_root)
    abs_new = File.expand_path(new_path, @operation_root)

    unless File.exist?(abs_old)
      puts "Error: source path does not exist on disk: #{abs_old}"
      return
    end

    # Move on disk
    FileUtils.mv(abs_old, abs_new)
    puts "Renamed on disk: #{abs_old} → #{abs_new}"

    old_rel = relative_path(abs_old)
    new_rel = relative_path(abs_new)

    # Check if it's a file or folder
    file_ref = @project.files.find { |f| f.path == old_rel }
    if file_ref
      # It's a file, just update its path in Xcode
      file_ref.path = new_rel
      puts "Updated Xcode file: #{old_rel} → #{new_rel}"
    else
      # Assume it's a folder/group
      group = find_group_by_path(old_rel)
      unless group
        puts "Warning: path not found in project: #{old_rel}"
        return
      end

      group.name = File.basename(new_rel)
      group.path = nil
      update_paths_recursive(group, new_rel)
      puts "Updated Xcode group: #{old_rel} → #{new_rel}"
    end
  end

  def update_paths_recursive(group, base_rel_path)
    # Update files
    group.files.each do |f|
      next unless f.path
      f.path = File.join(base_rel_path, File.basename(f.path))
    end

    # Update subgroups
    group.groups.each do |g|
      next unless g.path
      new_path = File.join(base_rel_path, File.basename(g.path))
      g.path = nil   # Treat as relative to parent
      g.name = File.basename(new_path)
      update_paths_recursive(g, new_path)
    end
  end

  # --- Build / Run ---
  def build
    config  = @options[:release] ? "Release" : "Debug"
    derived = @options[:derived_data] || "./.build/#{@project_name}"
    scheme  = @project.targets.first.name

    cmd = ["xcodebuild", "-json", "-project", @project_path, "-scheme", scheme,
           "-configuration", config, "-derivedDataPath", derived, "-quiet"]

    puts "Building #{config}..."
    errors = []
    #spinner = TTY::Spinner.new("[:spinner] Building...", format: :dots)
    spinner = TTY::Spinner.new(":spinner Building ...", format: :dots, success_mark: "✔".green, error_mark: "✘".red)
    spinner.auto_spin

    Open3.popen3(*cmd) do |stdin, stdout, stderr, wait_thr|
      handle_line = proc do |line|
        begin
          JSON.parse(line)
        rescue JSON::ParserError
          errors << line.strip if line.match(/:\d+:\d+:\s+error:/) || line.match(/^error:/)
        end
      end
      t1 = Thread.new { stdout.each_line { |l| handle_line.call(l) } }
      t2 = Thread.new { stderr.each_line { |l| handle_line.call(l) } }
      t1.join; t2.join

      status = wait_thr.value
      status.success? ? spinner.success("succeeded".green) : spinner.error("failed".red)
      if !status.success? && errors.any?
        puts "\nErrors:\n"
        errors.uniq.each { |e| puts e }
      end
      spinner.stop
      return status.success?
    end
  end

  def run_app
    build
    config = @options[:release] ? "Release" : "Debug"
    target = @project.targets.first
    product = File.basename(target.product_reference.path)
    derived = @options[:derived_data] || "./.build/#{@project_name}"
    path = File.join(derived, "Build", "Products", config, product)

    unless File.exist?(path)
      puts "Built product not found at #{path}"
      return
    end

    if @options[:console]
      executable = File.join(path, "Contents", "MacOS", File.basename(product, ".app"))
      unless File.exist?(executable)
        puts "Executable not found at #{executable}"
        return
      end
      puts "Launching in console: #{executable}"
      exec(executable)
    else
      puts "Launching #{path}"
      system("open", path)
    end
  end

  # --- Helpers ---
  def require_project!; exit puts("No .xcodeproj found.") unless @project; end

  def find_project_root
    dir = Dir.pwd
    loop do
      proj = Dir.glob(File.join(dir, "*.xcodeproj")).first
      return [dir, proj] if proj
      parent = File.expand_path("..", dir)
      break if parent == dir
      dir = parent
    end
    nil
  end

  def same_path?(a, b) = File.expand_path(a) == File.expand_path(b)
  def relative_path(file) = Pathname.new(File.expand_path(file)).relative_path_from(Pathname.new(@project_root)).to_s

  def find_group_by_path(rel_path, group = @project.main_group)
    return nil if rel_path.nil? || rel_path.empty?

    parts = rel_path.split(File::SEPARATOR)
    current = group
    parts.each do |part|
      current = current.groups.find { |g| g.name == part || (g.path && File.basename(g.path) == part) }
      return nil unless current
    end
    current
  end

  def resolve_targets
    return @project.targets.map(&:name) if @options[:all_targets] || @options[:targets].empty?
    @options[:targets]
  end

  def bundle_directory?(path)
    %w[.xcassets .bundle .framework .app].any? { |ext| File.basename(path).end_with?(ext) }
  end

  def enclosing_bundle(path)
    current = File.expand_path(path)
    loop do
      return current if bundle_directory?(current)
      parent = File.expand_path("..", current)
      return nil if parent == current
      current = parent
    end
  end

  def help
    puts <<~HELP
    xc #{@version}
    Usage: xc <command> [path] [options]

    Commands:
        add <path>           — Add a file or folder to the Xcode project
        remove <path>        — Remove a file or folder from the Xcode project
        rename <old> <new>   — Rename a file or folder in the Xcode project
        build                — Build the first target in the project
        run                  — Build and run the first target
        targets              — List available targets
        list                 — List files by target (includes implicit Swift files)
        open                 — Open the Xcode project in Xcode
        --help, -h           — Show this help message

    Options (can be combined with add, remove, rename, build, or run):
        --target NAME        — Operate only on the target with the given NAME
        --all-targets        — Operate on all targets in the project
        --verbose            — Print detailed actions as they happen
        --release            — Build using the Release configuration (default is Debug)
        --derived-data-path PATH — Specify custom derived data path for build (default is .build)
        --console            — Run the binary directly instead of using open
    HELP
  end
end

XC.new.run
